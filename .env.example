# AusaGuide Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is in .gitignore.

# ── Supabase ──────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Mapbox ────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ── Stripe (frontend public key only) ────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# ─────────────────────────────────────────────────────────
# SECURITY NOTES:
# - NEVER put SUPABASE_SERVICE_ROLE_KEY in .env for the frontend
# - Service role key belongs ONLY in Supabase Edge Function secrets
# - The anon key (sb_publishable_*) is safe for frontend use
# - All other secrets go in Supabase Dashboard → Edge Functions → Secrets
# -────────────────────────────────────────────────────────
